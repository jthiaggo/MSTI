################ Script PowerShell para gerar falhas de login

$users = Get-Content .\users.txt
$domain = "msti"
$target = "\\msti.com\SYSVOL"

foreach ($user in $users) {
    $username = "$domain\$user"
    $password = ConvertTo-SecureString "WrongPassword123!" -AsPlainText -Force
    $cred = New-Object System.Management.Automation.PSCredential($username,$password)

    try {
        New-PSDrive -Name "Z" -PSProvider FileSystem -Root $target -Credential $cred -ErrorAction Stop
    } catch {
        Write-Host "Falha para $username"
    }

    Remove-PSDrive Z -ErrorAction SilentlyContinue
}



